# Zadarma credentials — managed via 1Password.
# Resolve with: op inject -i .env.example -o ~/.hermes/.env
#
# Adjust the vault and item names below to match your 1Password setup.

ZADARMA_KEY="op://Personal/Zadarma/key"
ZADARMA_SECRET="op://Personal/Zadarma/secret"
ZADARMA_FROM="op://Personal/Zadarma/phone"
